{
  "name": "force-refresh",
  "version": "2.17.0-7617D9.1",
  "description": "Force Refresh is a simple plugin that allows you to force a page refresh for users currently visiting your site.",
  "url": "https://github.com/jordanleven/force-refresh",
  "repository": {
    "type": "git",
    "url": "https://github.com/jordanleven/force-refresh.git"
  },
  "author": "Jordan Leven",
  "license": "MIT",
  "scripts": {
    "prebuild": "npm run checkNodeVersion",
    "build": "npx webpack --mode=production",
    "build:dev": "npm run changelog:build && npx webpack --mode=development",
    "build:beta": "npm run changelog:build && npm run build",
    "predev": "npm run checkNodeVersion",
    "dev": "npm run build:dev -- --watch",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:qa": "playwright test --config=playwright.config.qa.ts",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint '**/*.{scss,vue}' --formatter verbose",
    "lint:js": "eslint .",
    "changelog:build": "node ./.github/scripts/createWordPressReadMe.js",
    "changelog:new": "npx changie new",
    "changelog:preview": "./.github/scripts/previewRelease.sh",
    "release": "./.github/scripts/release.sh",
    "release:beta": "./.github/scripts/releaseBeta.sh",
    "checkNodeVersion": "check-node-version --package",
    "db:update": "./db/updateDatabases.sh"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.0.6",
    "compare-versions": "^6.1.1",
    "html-entities": "^2.5.2",
    "qs": "^6.15.1",
    "ramda": "^0.32.0",
    "regenerator-runtime": "^0.14.1",
    "sprintf-js": "^1.1.3",
    "uniqid": "^5.4.0",
    "vue": "^3.5.13",
    "vue-datepicker-next": "^1.0.3",
    "vue-i18n": "^11.3.2",
    "vue-types": "^6.0.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vue/compiler-sfc": "^3.5.32",
    "@vue/test-utils": "^2.4.6",
    "babel-loader": "^10.1.1",
    "changie": "^1.24.0",
    "check-node-version": "^4.2.1",
    "css-loader": "^7.1.4",
    "dedent": "^1.7.2",
    "eslint": "^10.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "md-2-json": "^2.0.0",
    "postcss": "^8.5.9",
    "postcss-html": "^1.8.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "simple-git": "^3.35.2",
    "style-loader": "^4.0.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-processor-html": "^1.0.0",
    "typescript": "^6.0.2",
    "url-loader": "^4.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-loader": "^17.4.2",
    "vue3-jest": "^27.0.0-alpha.1",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "webpack-livereload-plugin": "^3.0.2"
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=6.0.0"
  }
}
